{
  "name": "texpand-vscode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "l10n": "./l10n",
  "version": "0.2.0",
  "publisher": "explodingkonjac",
  "repository": {
    "type": "git",
    "url": "https://github.com/ExplodingKonjac/OITools_Template-Expand"
  },
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "ms-vscode.wasm-wasi-core"
  ],
  "contributes": {
    "commands": [
      {
        "command": "texpand.expandDefault",
        "title": "%texpand.command.expandDefault.title%",
        "icon": "$(file-code)"
      },
      {
        "command": "texpand.expandAndCopy",
        "title": "%texpand.command.expandAndCopy.title%",
        "icon": "$(copy)"
      },
      {
        "command": "texpand.expandToNewFile",
        "title": "%texpand.command.expandToNewFile.title%",
        "icon": "$(new-file)"
      }
    ],
    "configuration": {
      "title": "%texpand.configuration.title%",
      "properties": {
        "texpand.includePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "./"
          ],
          "description": "%texpand.configuration.includePaths.description%"
        },
        "texpand.defaultCompression": {
          "type": "boolean",
          "default": false,
          "description": "%texpand.configuration.defaultCompression.description%"
        },
        "texpand.outputMode": {
          "type": "string",
          "enum": [
            "clipboard",
            "newFile"
          ],
          "default": "clipboard",
          "enumDescriptions": [
            "%texpand.configuration.outputMode.enumDescription.clipboard%",
            "%texpand.configuration.outputMode.enumDescription.newFile%"
          ],
          "description": "%texpand.configuration.outputMode.description%"
        },
        "texpand.saveBeforeExpansion": {
          "type": "boolean",
          "default": true,
          "description": "%texpand.configuration.saveBeforeExpansion.description%"
        }
      }
    },
    "submenus": [
      {
        "id": "texpand.contextMenu",
        "label": "%texpand.submenu.label%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "texpand.expandAndCopy",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "submenu": "texpand.contextMenu",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "texpand"
        }
      ],
      "texpand.contextMenu": [
        {
          "command": "texpand.expandAndCopy",
          "group": "texpand"
        },
        {
          "command": "texpand.expandToNewFile",
          "group": "texpand"
        }
      ]
    }
  },
  "scripts": {
    "wasm:compile": "cargo build -p texpand-vscode --target wasm32-wasip1 --release",
    "wasm:optimize": "wasm-opt -Os --enable-bulk-memory --all-features -o ./pkg/texpand-vscode.wasm ../../target/wasm32-wasip1/release/texpand-vscode.wasm",
    "wasm:build": "npm-run-all wasm:compile wasm:optimize",
    "esbuild:base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:ext": "npm run esbuild:base -- --minify",
    "typecheck": "tsc --noEmit -p ./",
    "watch": "npm run esbuild:base -- --watch=forever",
    "vscode:prepublish": "npm-run-all wasm:build build:ext",
    "package": "vsce package",
    "l10n:export": "npx @vscode/l10n-dev export --outDir ./l10n ./src"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/l10n-dev": "^0.0.35",
    "esbuild": "^0.28.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.9.3",
    "wasm-opt": "^1.4.0"
  },
  "dependencies": {
    "@vscode/vsce": "^3.9.1",
    "@vscode/wasm-wasi": "^1.0.0"
  }
}
